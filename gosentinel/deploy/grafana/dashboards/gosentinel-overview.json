{
  "title": "GoSentinel — Overview (Four Golden Signals + RED + USE)",
  "uid": "gosentinel-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["gosentinel", "observability"],
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Request Rate (Traffic)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{namespace=\"gosentinel\"}[5m]))",
        "legendFormat": "req/s"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":100},{"color":"red","value":1000}] }
      }}
    },
    {
      "id": 2, "type": "stat", "title": "Error Rate (Errors)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{namespace=\"gosentinel\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"gosentinel\"}[5m]))",
        "legendFormat": "error %"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit",
        "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":0.01},{"color":"red","value":0.05}] }
      }}
    },
    {
      "id": 3, "type": "stat", "title": "P99 Latency (Latency)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"gosentinel\"}[5m])) by (le))",
        "legendFormat": "p99"
      }],
      "fieldConfig": { "defaults": { "unit": "s",
        "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":0.5},{"color":"red","value":1.0}] }
      }}
    },
    {
      "id": 4, "type": "stat", "title": "CPU Saturation",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"gosentinel\"}[5m])) / sum(kube_pod_container_resource_limits{namespace=\"gosentinel\",resource=\"cpu\"})",
        "legendFormat": "cpu util"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit",
        "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":0.7},{"color":"red","value":0.9}] }
      }}
    },
    {
      "id": 5, "type": "timeseries", "title": "Request Rate by Service",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{namespace=\"gosentinel\"}[5m])) by (service)",
        "legendFormat": "{{ service }}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" }}
    },
    {
      "id": 6, "type": "timeseries", "title": "Latency Percentiles (p50/p95/p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"gosentinel\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"gosentinel\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"gosentinel\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }}
    },
    {
      "id": 7, "type": "timeseries", "title": "Correlation Events & Anomalies",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(pipeline_correlation_events_total[5m])", "legendFormat": "correlated/s" },
        { "expr": "rate(pipeline_anomalies_detected_total[5m])", "legendFormat": "anomalies/s" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "SLO Error Budget Burn Rate",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "pipeline_slo_burn_rate", "legendFormat": "burn rate" },
        { "expr": "14.4", "legendFormat": "fast burn threshold" },
        { "expr": "6", "legendFormat": "slow burn threshold" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }}
    },
    {
      "id": 9, "type": "timeseries", "title": "Goroutines & Memory (USE: Saturation)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        { "expr": "process_goroutines{namespace=\"gosentinel\"}", "legendFormat": "goroutines — {{ pod }}" },
        { "expr": "process_heap_inuse_bytes{namespace=\"gosentinel\"} / 1024 / 1024", "legendFormat": "heap MiB — {{ pod }}" }
      ]
    },
    {
      "id": 10, "type": "table", "title": "Active Alerts",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [{
        "expr": "ALERTS{namespace=\"gosentinel\",alertstate=\"firing\"}",
        "legendFormat": "{{ alertname }} — {{ severity }}"
      }]
    }
  ]
}
