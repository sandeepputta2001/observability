# GoSentinel Alert Channel Configuration
# Copy this file to .env and fill in your credentials.
# docker compose will automatically load .env
#
# All channels are optional. GoSentinel only registers channels
# that have credentials set. Channels with empty values are skipped.

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
GOSENTINEL_ALERTING_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../...

# ── PagerDuty ─────────────────────────────────────────────────────────────────
# Create an Events API v2 integration in your PagerDuty service
GOSENTINEL_ALERTING_PAGERDUTY_KEY=your-pagerduty-integration-key

# ── Gmail (SMTP) ──────────────────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Use that 16-character password below (NOT your account password)
GOSENTINEL_ALERTING_GMAIL_USERNAME=alerts@yourdomain.com
GOSENTINEL_ALERTING_GMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Comma-separated list of recipient addresses
GOSENTINEL_ALERTING_GMAIL_TO=oncall@yourdomain.com,team@yourdomain.com
# SMTP host (default: smtp.gmail.com — change for other providers)
GOSENTINEL_ALERTING_SMTP_HOST=smtp.gmail.com
# SMTP port: 587 (STARTTLS, default) or 465 (implicit TLS)
GOSENTINEL_ALERTING_SMTP_PORT=587

# ── OpsGenie ──────────────────────────────────────────────────────────────────
# Create an API integration in OpsGenie and copy the API key
GOSENTINEL_ALERTING_OPSGENIE_KEY=your-opsgenie-api-key
# Region: "us" (default) or "eu"
GOSENTINEL_ALERTING_OPSGENIE_REGION=us

# ── Microsoft Teams ───────────────────────────────────────────────────────────
# Create an Incoming Webhook connector in your Teams channel
# https://learn.microsoft.com/en-us/microsoftteams/platform/webhooks-and-connectors/how-to/add-incoming-webhook
GOSENTINEL_ALERTING_TEAMS_WEBHOOK=https://yourorg.webhook.office.com/webhookb2/...

# ── Generic Webhook ───────────────────────────────────────────────────────────
# Any HTTP endpoint that accepts POST with JSON body
GOSENTINEL_ALERTING_WEBHOOK_URL=https://your-service.example.com/alerts
# Optional HMAC-SHA256 signing secret — sent as X-GoSentinel-Signature header
GOSENTINEL_ALERTING_WEBHOOK_SECRET=your-webhook-secret

# ── Deduplication ─────────────────────────────────────────────────────────────
# Suppress duplicate notifications for the same (rule, state) within this window
GOSENTINEL_ALERTING_DEDUP_TTL=10m

# ── Core Services ─────────────────────────────────────────────────────────────
# These are set automatically by docker-compose. Override only if needed.
# GOSENTINEL_OTLP_ENDPOINT=localhost:4317
# GOSENTINEL_VICTORIA_METRICS_ENDPOINT=http://localhost:8428
# GOSENTINEL_JAEGER_ENDPOINT=localhost:16685
# GOSENTINEL_LOKI_ENDPOINT=http://localhost:3100
# GOSENTINEL_PYROSCOPE_ENDPOINT=http://localhost:4040
# GOSENTINEL_POSTGRES_DSN=postgres://gosentinel:gosentinel@localhost:5432/gosentinel?sslmode=disable
# GOSENTINEL_API_JWT_SECRET=dev-secret-change-in-production
